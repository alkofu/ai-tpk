# Match CLAUDE_WHITELIST_DIRS and CLAUDE_WHITELIST_FILES in src/installer/constants.ts
claude/**
!claude/CLAUDE.md
!claude/settings.json
!claude/skills/
!claude/skills/**
!claude/agents/
!claude/agents/**
!claude/hooks/
!claude/hooks/**
!claude/commands/
!claude/commands/**
!claude/references/
!claude/references/**
!claude/scripts/
!claude/scripts/**

# Git worktrees
.worktrees/

# Superpowers working files
docs/superpowers/

# Session logs (generated by Talekeeper hooks and agent)
logs/

# Node.js
node_modules/

# Build output
dist/

# Legacy local plans directory (migrated to ~/.ai-tpk/plans/)
plans/

# Local lessons directory (migrated to ~/.ai-tpk/lessons/)
lessons/

# Lefthook local overrides (machine-specific, not for version control)
lefthook-local.yml

# Python (dungeon/)
# `uv sync` creates `.venv/` directly under `dungeon/`, so an anchored pattern is used.
# `dist/` is already covered by the global unanchored `dist/` rule above.
# Cache directories (`__pycache__`, `.pytest_cache`, `.ruff_cache`, `.mypy_cache`,
# `*.egg-info`) can appear at any depth under the package or test trees, so they are globbed.
dungeon/.venv/
dungeon/**/__pycache__/
dungeon/**/.pytest_cache/
dungeon/**/.ruff_cache/
dungeon/**/.mypy_cache/
dungeon/**/*.egg-info/
