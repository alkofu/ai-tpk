{
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/yaml": "jsr:@std/yaml@^1"
  },
  "tasks": {
    "to-claude": "deno run --allow-read --allow-write adapters/to-claude.ts",
    "to-opencode": "deno run --allow-read --allow-write adapters/to-opencode.ts",
    "validate": "deno run --allow-read --allow-write --allow-run=git adapters/validate.ts",
    "check": "deno check adapters/**/*.ts",
    "lint": "deno lint",
    "fmt-check": "deno fmt --check",
    "test": "deno test --allow-read --allow-write --allow-run=deno adapters/"
  }
}
