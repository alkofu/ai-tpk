{
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash claude/hooks/talekeeper-capture.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "async": true,
        "hooks": [
          {
            "type": "command",
            "command": "bash claude/hooks/talekeeper-enrich.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "defaultMode": "dontAsk",
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  }
}
