{
  "servers": [
    {
      "name": "kubernetes",
      "scope": "user",
      "transport": "stdio",
      "prereq": "$HOME/.kube/config",
      "env": { "KUBECONFIG": "$HOME/.kube/config" },
      "command": "npx",
      "args": ["--yes", "mcp-server-kubernetes@3.4.0"]
    },
    {
      "name": "cloudwatch",
      "scope": "user",
      "transport": "stdio",
      "prereq": "$HOME/.aws/credentials",
      "wrapper": "wrappers/mcp-cloudwatch.sh"
    },
    {
      "name": "grafana",
      "scope": "user",
      "transport": "stdio",
      "wrapper": "wrappers/mcp-grafana.sh"
    },
    {
      "name": "github",
      "scope": "user",
      "transport": "stdio",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      },
      "command": "npx",
      "args": ["--yes", "@modelcontextprotocol/server-github"],
      "_note": "Package archived 2025-05-29. Successor: ghcr.io/github/github-mcp-server (requires Docker). Using npm package for zero-dependency install."
    },
    {
      "name": "gcp-observability",
      "scope": "user",
      "transport": "stdio",
      "prereq": "$HOME/.config/gcloud/application_default_credentials.json",
      "wrapper": "wrappers/mcp-gcp-observability.sh"
    }
  ]
}
