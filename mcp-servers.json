{
  "servers": [
    {
      "name": "kubernetes",
      "scope": "user",
      "transport": "stdio",
      "prereq": "$HOME/.kube/config",
      "env": { "KUBECONFIG": "$HOME/.kube/config" },
      "command": "npx",
      "args": ["--yes", "mcp-server-kubernetes@3.4.0"]
    },
    {
      "name": "cloudwatch",
      "scope": "user",
      "transport": "stdio",
      "prereq": "$HOME/.aws/credentials",
      "wrapper": "wrappers/mcp-cloudwatch.sh"
    },
    {
      "name": "grafana",
      "scope": "user",
      "transport": "stdio",
      "wrapper": "wrappers/mcp-grafana.sh"
    }
  ]
}
