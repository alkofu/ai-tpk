{
  "name": "ai-tpk",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "lefthook"]
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsx build.ts",
    "setup": "node dist/installer.js",
    "launch": "tsx src/launcher/main.ts",
    "test": "node --import tsx/esm --test 'src/installer/**/*.test.ts' 'src/launcher/**/*.test.ts'",
    "lint": "oxlint src/installer/ src/launcher/",
    "format": "oxfmt --write src/installer/ src/launcher/",
    "format:check": "oxfmt --check src/installer/ src/launcher/"
  }
}
