{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "ES2023.Array"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/installer/**/*.ts", "src/launcher/**/*.ts", "build.ts"]
}
